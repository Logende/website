{
  "type": "object",
  "properties": {
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "abstract": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "conference": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "ConferencePaper",
                "ConferenceTalk",
                "JournalPaper",
                "OtherTalk",
                "ThesisSupervision",
                "MasterThesis",
                "BachelorThesis",
                "ResearchProject",
                "WorkshopTalk",
                "Poster"
              ]
            }
          },
          "supervised_by": {
            "description": "Name of the supervisor (use when this publication is student work supervised by someone)",
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "doi": {
            "type": "string"
          },
          "link": {
            "description": "Use only when no DOI is available",
            "type": "string",
            "format": "uri"
          },
          "related_projects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "derived_from": {
            "description": "Use when this publication is derived from another publication (e.g., a conference paper that was extended to a journal paper). Provide the DOI of the original publication.",
            "type": "string"
          }
        },
        "required": [
          "title",
          "authors",
          "conference",
          "date",
          "tags",
          "related_project_ids"
        ]
      }
    }
  }
}
